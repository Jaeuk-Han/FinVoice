# =====================================================================
#  .env.example — 환경변수 자리표시자 + 발급 안내
# ---------------------------------------------------------------------
#  사용법:  copy .env.example .env   (Windows)  /  cp .env.example .env
#  그다음 아래 your_xxx 자리에 "본인이 발급받은 실제 값"을 채운다.
#
#  ⚠️ .env 는 절대 git 에 커밋하지 않는다 (.gitignore 에 등록되어 있음).
#  ⚠️ 이 파일(.env.example)에는 실제 키/비밀번호를 절대 적지 않는다 — 자리표시자만.
#  값은 서로 다른 3곳에서 발급된다(아래 [발급처] 표기 참고). 헷갈리지 말 것.
# =====================================================================


# ── [발급처 A] 외부 금융뉴스 (NCP 아님) ──────────────────────────────
#   finnhub.io 무료 가입 → Dashboard 의 API Key 복사.
#   사용처: pipeline/fetch.py (company-news 조회)
NEWS_API_KEY=your_finnhub_key


# ── [발급처 B] NCP AI·NAVER API "Application" — 파파고(+선택적으로 음성) ──
#   NCP 콘솔 → AI·Application Service → AI·NAVER API → Application 등록.
#   * 등록하면 나오는 Client ID = KEY_ID, Client Secret = KEY.
#   * 앱 1개로 운영하려면: 이 Application 에 "Papago Text Translation" +
#     "CLOVA Voice - Premium" 두 서비스를 모두 추가하고 아래 B 키만 채운다
#     (그러면 음성도 이 키로 폴백 동작 — 아래 B2 는 비워둬도 됨).
#   사용처: pipeline/translate.py(Papago) — 음성도 B2 미설정 시 이 키 사용
NCP_APIGW_KEY_ID=your_papago_client_id
NCP_APIGW_KEY=your_papago_client_secret

# ── [발급처 B2] CLOVA Voice 를 "별도 Application" 으로 등록한 경우만 ──────
#   파파고와 음성을 서로 다른 앱으로 만들었다면(키 쌍이 2개), 음성 앱의
#   Client ID/Secret 을 여기에 넣는다. 한 앱으로 합쳤다면 비워둘 것(B 로 폴백).
#   사용처: pipeline/tts.py(CLOVA Voice) — 설정 시 B 보다 우선
NCP_VOICE_KEY_ID=
NCP_VOICE_KEY=


# ── [발급처 C] CLOVA Studio (요약 전용, 위 B와 별개!) ────────────────
#   NCP 콘솔 → CLOVA Studio → 테스트앱/서비스앱 생성 → API Key 발급.
#   * 이 키는 "nv-" 로 시작하는 Bearer 키다 (구 testapp 이중키 아님).
#   * 코드가 Authorization: Bearer <이 값> 으로 호출한다.
#   사용처: pipeline/summarize.py (HCX 요약 + 감성 판단)
CLOVA_STUDIO_API_KEY=your_clovastudio_bearer_key


# ── [발급처 D] Object Storage 인증키 (위 B/C와 또 별개!) ─────────────
#   ACCESS/SECRET: NCP 콘솔 → 마이페이지 → 계정 관리 → 인증키 관리.
#   BUCKET: Object Storage 에서 버킷 생성 후 그 이름을 적는다.
#           (mp3 는 코드가 public-read 로 업로드 → 재생 URL 노출)
#   ENDPOINT/리전(kr-standard)은 KR 기본값이라 보통 그대로 둔다.
#   사용처: pipeline/tts.py (mp3 업로드 후 재생 URL 반환)
NCP_OS_ACCESS_KEY=your_account_access_key
NCP_OS_SECRET_KEY=your_account_secret_key
NCP_OS_ENDPOINT=https://kr.object.ncloudstorage.com
NCP_OS_BUCKET=stock-briefing-audio


# ── [발급처 E] MySQL 접속정보 ────────────────────────────────────────
#   로컬 검증: 로컬 MySQL 에 DB 생성 후 scripts/init_db.sql 적용.
#   서버 운영: NCP Cloud DB for MySQL 인스턴스 정보 사용.
#   사용처: app/db.py (briefing / briefing_item / article 저장·조회)
DB_HOST=your_db_host
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=stock_briefing
